# ── Supabase ──────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── JWT ───────────────────────────────────────────────────────────
# Generate a strong random secret:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-string

# ── CORS ──────────────────────────────────────────────────────────
# Your Vercel frontend URL (no trailing slash). Use * only for local dev.
CORS_ORIGIN=https://your-app.vercel.app

# ── Server ────────────────────────────────────────────────────────
PORT=3000
